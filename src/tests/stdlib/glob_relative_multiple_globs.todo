import * from "std/fs"
import * from "std/text"

// Output
// [file1.txt]
// [file2.txt]
// [other.csv]
// [other1.csv]
// [other2.csv]
// [other99.csv]

main {
    let tmpdir = trust $ mktemp -d $
    trust {
        $ touch {tmpdir}/1st\ file\ with\ spaces.txt $
        $ touch {tmpdir}/2nd\ file\ with\ spaces.txt $
        $ touch {tmpdir}/file1.txt $
        $ touch {tmpdir}/file2.txt $
        $ touch {tmpdir}/other.csv $
        $ touch {tmpdir}/other1.csv $
        $ touch {tmpdir}/other2.csv $
        $ touch {tmpdir}/other99.csv $
    }
    cd tmpdir

    let files = glob(["missing*", "file*", "*.csv"]) failed { echo "*glob failed*" }
    loop file in files {
        echo "[{file}]"
    }

    trust $ rm -rf {tmpdir} $
}
